generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model herramienta {
  id_herramienta   Int                @id
  nombre           String             @db.VarChar(50)
  descripcion      String?
  recoleccion_info recoleccion_info[]
}

model metodo_recoleccion {
  id_metodo        Int                @id
  nombre           String             @db.VarChar(50)
  descripcion      String?
  tipo_metodologia String?            @db.VarChar(30)
  recoleccion_info recoleccion_info[]
}

model proceso {
  id_proceso   Int          @id @default(autoincrement())
  nombre       String       @db.VarChar(50)
  descripcion  String?
  id_proyecto  Int?
  codigo_orden Int?
  proyecto     proyecto?    @relation(fields: [id_proyecto], references: [id_proyecto], onDelete: Cascade, onUpdate: NoAction)
  subproceso   subproceso[]
}

model proceso_stakeholder_participacion {
  id_proceso     Int
  id_stakeholder Int
  id_rol         Int
  rol            rol @relation(fields: [id_rol], references: [id_rol], onDelete: Cascade, onUpdate: NoAction)

  @@id([id_proceso, id_stakeholder, id_rol])
}

model proyecto {
  id_proyecto           Int                     @id @default(autoincrement())
  nombre                String?                 @db.VarChar(50)
  descripcion           String?
  problema_a_resolver   String?
  fecha_inicio          DateTime?               @db.Date
  fecha_fin             DateTime?               @db.Date
  estatus               String?                 @default("Planificación") @db.VarChar(20)
  id_usuario_creador    Int?
  proceso               proceso[]
  usuario               usuario?                @relation(fields: [id_usuario_creador], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  proyecto_participante proyecto_participante[]
  stakeholder           stakeholder[]
}

model proyecto_participante {
  id_participacion Int       @id @default(autoincrement())
  id_proyecto      Int
  id_usuario       Int
  id_rol           Int
  fecha_asignacion DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  activo           Boolean?  @default(true)
  fecha_salida     DateTime? @db.Date
  proyecto         proyecto  @relation(fields: [id_proyecto], references: [id_proyecto], onDelete: Cascade, onUpdate: NoAction)
  rol              rol       @relation(fields: [id_rol], references: [id_rol], onDelete: NoAction, onUpdate: NoAction)
  usuario          usuario   @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@unique([id_proyecto, id_usuario, id_rol])
}

model recoleccion_info {
  id_recoleccion      Int                 @id
  id_subproceso       Int?
  id_metodo           Int?
  id_herramienta      Int?
  fecha_aplicacion    DateTime?           @default(now()) @db.Timestamp(6)
  resultado_obtenido  String?
  archivo_adjunto_url String?
  herramienta         herramienta?        @relation(fields: [id_herramienta], references: [id_herramienta], onDelete: NoAction, onUpdate: NoAction)
  metodo_recoleccion  metodo_recoleccion? @relation(fields: [id_metodo], references: [id_metodo], onDelete: NoAction, onUpdate: NoAction)
}

model rol {
  id_rol                            Int                                 @id @default(autoincrement())
  nombre                            String                              @db.VarChar(30)
  estatus                           String?                             @db.Char(1)
  proceso_stakeholder_participacion proceso_stakeholder_participacion[]
  proyecto_participante             proyecto_participante[]
  stakeholder                       stakeholder[]
}

model stakeholder {
  id_stakeholder Int       @id @default(autoincrement())
  nombre         String    @db.VarChar(50)
  email          String?   @db.VarChar(50)
  id_rol         Int?
  estatus        String?   @default("A") @db.Char(1)
  id_proyecto    Int?
  proyecto       proyecto? @relation(fields: [id_proyecto], references: [id_proyecto], onDelete: NoAction, onUpdate: NoAction)
  rol            rol?      @relation(fields: [id_rol], references: [id_rol], onDelete: NoAction, onUpdate: NoAction)
}

model subproceso {
  id_subproceso Int      @id @default(autoincrement())
  nombre        String   @db.VarChar(100)
  descripcion   String?
  id_proceso    Int?
  codigo_orden  Int?
  proceso       proceso? @relation(fields: [id_proceso], references: [id_proceso], onDelete: Cascade, onUpdate: NoAction)
}

model usuario {
  id_usuario            Int                     @id
  nombre                String                  @db.VarChar(50)
  apellido_paterno      String                  @db.VarChar(50)
  apellido_materno      String?                 @db.VarChar(50)
  telefono              Int?
  email                 String                  @db.VarChar(100)
  estatus               String?                 @db.Char
  password_hash         String?                 @db.VarChar(100)
  proyecto              proyecto[]
  proyecto_participante proyecto_participante[]
}
