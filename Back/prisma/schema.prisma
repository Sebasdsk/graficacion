generator client {
  provider = "prisma-client-ts"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model diagrama_uml {
  id_diagrama   Int            @id @default(autoincrement())
  nombre        String         @db.VarChar(100)
  descripcion   String         @db.VarChar(150)
  tipo_diagrama tipo_diagrama?
  diagrama      String?
  estatus       String         @default("A") @db.VarChar(1)
  id_proyecto   Int?
  proyecto      proyecto?      @relation(fields: [id_proyecto], references: [id_proyecto], onDelete: NoAction, onUpdate: NoAction)
}

model entrevista {
  id_entrevista       Int                   @id @default(autoincrement())
  id_tecnica          Int
  id_usuario          Int
  fecha_entrevista    DateTime?             @db.Date
  duracion            Int?
  estatus             String                @db.VarChar(20)
  tecnica_recoleccion tecnica_recoleccion   @relation(fields: [id_tecnica], references: [id_tecnica], onDelete: Cascade)
  usuario             usuario               @relation(fields: [id_usuario], references: [id_usuario])
  pregunta_entrevista pregunta_entrevista[]
}

model equipo_proyecto {
  id_equipo   Int       @id @default(autoincrement())
  id_proyecto Int?
  id_usuario  Int?
  id_rol      Int?
  proyecto    proyecto? @relation(fields: [id_proyecto], references: [id_proyecto], onDelete: NoAction, onUpdate: NoAction)
  rol         rol?      @relation(fields: [id_rol], references: [id_rol], onDelete: NoAction, onUpdate: NoAction)
  usuario     usuario?  @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@unique([id_proyecto, id_usuario, id_rol])
}

model observacion {
  id_observacion      Int                   @id @default(autoincrement())
  ubicacion           String?               @db.VarChar(100)
  fecha               DateTime?             @db.Date
  duracion            Int?
  hallazgos           String?
  id_tecnica          Int?
  id_stakeholder      Int?
  stakeholder         stakeholder?          @relation(fields: [id_stakeholder], references: [id_stakeholder], onDelete: NoAction, onUpdate: NoAction)
  tecnica_recoleccion tecnica_recoleccion?  @relation(fields: [id_tecnica], references: [id_tecnica], onDelete: NoAction, onUpdate: NoAction, map: "fk_observacion_tecnica")
  observacion_detalle observacion_detalle[]
}

model pregunta_entrevista {
  id_pregunta    Int        @id @default(autoincrement())
  id_entrevista  Int
  orden_pregunta Int
  pregunta       String
  respuesta      String?
  entrevista     entrevista @relation(fields: [id_entrevista], references: [id_entrevista], onDelete: Cascade)
}

model cuestionario {
  id_cuestionario       Int       @id @default(autoincrement())
  id_tecnica            Int
  id_usuario            Int
  objetivo              String?   @db.Text
  audiencia_objetivo    String?   @db.Text
  responsable           String?   @db.VarChar(100)
  metodo_distribucion   String?   @db.VarChar(100)
  fecha_distribucion    DateTime? @db.Date
  fecha_limite          DateTime? @db.Date
  respuestas_recibidas  Int       @default(0)
  instrucciones         String?   @db.Text
  estatus               String    @default("Pendiente") @db.VarChar(20)

  tecnica   tecnica_recoleccion  @relation(fields: [id_tecnica], references: [id_tecnica], onDelete: Cascade)
  usuario   usuario              @relation(fields: [id_usuario], references: [id_usuario])
  preguntas pregunta_cuestionario[]
}

model pregunta_cuestionario {
  id_pregunta     Int     @id @default(autoincrement())
  id_cuestionario Int
  orden_pregunta  Int
  tipo_pregunta   String  @db.VarChar(20) 
  pregunta        String  @db.Text
  respuesta       String? @db.Text

  cuestionario cuestionario @relation(fields: [id_cuestionario], references: [id_cuestionario], onDelete: Cascade)
}

model focus_group {
  id_focus    Int       @id @default(autoincrement())
  id_tecnica  Int
  id_usuario  Int
  fecha       DateTime? @db.Date
  duracion    Int?                        // en minutos
  estatus     String    @default("Planificada") @db.VarChar(20)
  tema        String    @db.VarChar(200)
  conclusiones  String?   @db.Text
  idea        String?   @db.VarChar(50)

  tecnica      tecnica_recoleccion          @relation(fields: [id_tecnica], references: [id_tecnica], onDelete: Cascade)
  usuario      usuario                      @relation(fields: [id_usuario], references: [id_usuario])
  participantes participante_focus_group[]
}

model participante_focus_group {
  id_participante Int     @id @default(autoincrement())
  id_focus        Int
  id_stakeholder  Int
  contribuciones  String? @db.Text

  focus_group  focus_group @relation(fields: [id_focus], references: [id_focus], onDelete: Cascade)
  stakeholder  stakeholder @relation(fields: [id_stakeholder], references: [id_stakeholder], onDelete: Cascade)
}

model proceso {
  id_proceso  Int          @id @default(autoincrement())
  nombre      String       @db.VarChar(50)
  descripcion String?
  id_proyecto Int?
  estatus     String?      @default("A") @db.VarChar(1)
  id_rol      Int?
  proyecto    proyecto?    @relation(fields: [id_proyecto], references: [id_proyecto], onDelete: Cascade, onUpdate: NoAction)
  rol         rol?         @relation(fields: [id_rol], references: [id_rol], onDelete: NoAction, onUpdate: NoAction)
  subproceso  subproceso[]
}

model proyecto {
  id_proyecto           Int                     @id @default(autoincrement())
  nombre                String?                 @db.VarChar(50)
  descripcion           String?
  problema_a_resolver   String?
  fecha_inicio          DateTime?               @db.Date
  fecha_fin             DateTime?               @db.Date
  estatus               String?                 @default("Planificación") @db.VarChar(20)
  id_usuario_creador    Int?
  diagrama_uml          diagrama_uml[]
  equipo_proyecto       equipo_proyecto[]
  proceso               proceso[]
  usuario               usuario?                @relation(fields: [id_usuario_creador], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  proyecto_participante proyecto_participante[]
  rol                   rol[]
}

model proyecto_participante {
  id_participacion Int       @id @default(autoincrement())
  id_proyecto      Int
  id_usuario       Int
  id_rol           Int
  fecha_asignacion DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  activo           Boolean?  @default(true)
  fecha_salida     DateTime? @db.Date
  proyecto         proyecto  @relation(fields: [id_proyecto], references: [id_proyecto], onDelete: Cascade, onUpdate: NoAction)
  rol              rol       @relation(fields: [id_rol], references: [id_rol], onDelete: NoAction, onUpdate: NoAction)
  usuario          usuario   @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@unique([id_proyecto, id_usuario, id_rol])
}

model requerimiento {
  id_requerimiento    Int                 @id @default(autoincrement())
  descripcion         String
  codigo_unico        String              @db.VarChar(20)
  id_tecnica          Int
  tecnica_recoleccion tecnica_recoleccion @relation(fields: [id_tecnica], references: [id_tecnica], onDelete: Cascade, onUpdate: NoAction)
}

model rol {
  id_rol                Int                     @id @default(autoincrement())
  nombre                String                  @db.VarChar(30)
  estatus               String?                 @db.Char(1)
  descripcion           String?                 @db.Char(200)
  id_proyecto           Int?
  equipo_proyecto       equipo_proyecto[]
  proceso               proceso[]
  proyecto_participante proyecto_participante[]
  proyecto              proyecto?               @relation(fields: [id_proyecto], references: [id_proyecto], onDelete: NoAction, onUpdate: NoAction, map: "fk_rol_proyecto")
  stakeholder           stakeholder[]
}

model stakeholder {
  id_stakeholder      Int                   @id @default(autoincrement())
  nombre              String                @db.VarChar(100)
  area                String?               @db.VarChar(50)
  contacto_email      String?               @db.VarChar(60)
  estatus             String?               @default("A") @db.VarChar(1)
  id_rol              Int?
  observacion         observacion[]
  rol                 rol?                  @relation(fields: [id_rol], references: [id_rol], onDelete: NoAction, onUpdate: NoAction, map: "fk_stakeholder_rol")
  tecnica_recoleccion tecnica_recoleccion[]
  participacione participante_focus_group[]
  observacion         observacion[]
}

model subproceso {
  id_subproceso       Int                   @id @default(autoincrement())
  nombre              String                @db.VarChar(100)
  descripcion         String?
  estatus             String                @default("A") @db.VarChar(1)
  id_proceso          Int
  proceso             proceso               @relation(fields: [id_proceso], references: [id_proceso], onDelete: Cascade, onUpdate: NoAction)
  tecnica_recoleccion tecnica_recoleccion[]
}

model tecnica_recoleccion {
  id_tecnica                   Int                           @id @default(autoincrement())
  titulo                       String                        @db.VarChar(50)
  descripcion                  String?
  estatus                      String                        @default("A") @db.VarChar(1)
  id_subproceso                Int
  id_stakeholder               Int?
  id_tecnica_catalogo          Int?
  ultima_actualizacion         DateTime?                     @db.Date
  entrevista                   entrevista[]
  historia_usuario             historia_usuario[]
  observacion                  observacion[]
  requerimiento                requerimiento[]
  stakeholder                  stakeholder?                  @relation(fields: [id_stakeholder], references: [id_stakeholder], onDelete: Cascade, onUpdate: NoAction, map: "tecnica_id_stakeholder_fkey")
  subproceso                   subproceso                    @relation(fields: [id_subproceso], references: [id_subproceso], onDelete: Cascade, onUpdate: NoAction, map: "tecnica_id_subproceso_fkey")
  tecnica_recoleccion_catalogo tecnica_recoleccion_catalogo? @relation(fields: [id_tecnica_catalogo], references: [id_tecnica_catalogo], onDelete: NoAction, onUpdate: NoAction, map: "tecnica_id_tecnica_recoleccion_catalogo_fkey")
}

model usuario {
  id_usuario            Int                     @id @default(autoincrement())
  nombre                String                  @db.VarChar(50)
  apellido_paterno      String                  @db.VarChar(50)
  apellido_materno      String?                 @db.VarChar(50)
  telefono              Int?
  email                 String                  @db.VarChar(100)
  estatus               String?                 @db.VarChar(1)
  password_hash         String                  @db.VarChar(64)
  Nombre_usuario        String?                 @db.VarChar(32)
  entrevista            entrevista[]
  cuestionario  cuestionario[]
  focus_group           focus_group[]
  equipo_proyecto       equipo_proyecto[]
  proyecto              proyecto[]
  proyecto_participante proyecto_participante[]
}

model tecnica_recoleccion_catalogo {
  id_tecnica_catalogo Int                   @id @default(autoincrement())
  nombre              String                @db.VarChar(60)
  tecnica_recoleccion tecnica_recoleccion[]
}

model criterio_aceptacion {
  id_criterio        Int               @id @default(autoincrement())
  descripcion        String            @db.VarChar(50)
  id_historia_usario Int?
  historia_usuario   historia_usuario? @relation(fields: [id_historia_usario], references: [id_historia_usario], onDelete: NoAction, onUpdate: NoAction, map: "criterio_aceptacion_id_historia_usuario_fkey")
}

model historia_usuario {
  id_historia_usario  Int                   @id @default(autoincrement())
  titulo              String                @db.VarChar(50)
  autor               String                @db.VarChar(30)
  objetivo            String                @db.VarChar(50)
  proposito           String                @db.VarChar(100)
  id_tecnica          Int?
  criterio_aceptacion criterio_aceptacion[]
  tecnica_recoleccion tecnica_recoleccion?  @relation(fields: [id_tecnica], references: [id_tecnica], onDelete: NoAction, onUpdate: NoAction)
}

model observacion_detalle {
  id_observacion_detalle Int          @id @default(autoincrement())
  hora                   String       @db.VarChar(30)
  categoria              String       @db.VarChar(100)
  descripcion            String?
  id_observacion         Int?
  observacion            observacion? @relation(fields: [id_observacion], references: [id_observacion], onDelete: NoAction, onUpdate: NoAction)
}

enum tipo_diagrama {
  use_case @map("use-case")
  class
  sequence
  package
}

enum prioridad_historia_usuario {
  Alta
  Media
  Baja
}
