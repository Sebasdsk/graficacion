generator client {
  provider = "prisma-client-ts"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model proceso {
  id_proceso   Int          @id @default(autoincrement())
  nombre       String       @db.VarChar(50)
  descripcion  String?
  id_proyecto  Int?
  codigo_orden String?      @db.VarChar(10)
  proyecto     proyecto?    @relation(fields: [id_proyecto], references: [id_proyecto], onDelete: Cascade, onUpdate: NoAction)
  subproceso   subproceso[]
}

model proyecto {
  id_proyecto           Int                     @id @default(autoincrement())
  nombre                String?                 @db.VarChar(50)
  descripcion           String?
  problema_a_resolver   String?
  fecha_inicio          DateTime?               @db.Date
  fecha_fin             DateTime?               @db.Date
  estatus               String?                 @default("Planificación") @db.VarChar(20)
  id_usuario_creador    Int?
  equipo_proyecto       equipo_proyecto[]
  proceso               proceso[]
  usuario               usuario?                @relation(fields: [id_usuario_creador], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  proyecto_participante proyecto_participante[]
  rol                   rol[]
}

model proyecto_participante {
  id_participacion Int       @id @default(autoincrement())
  id_proyecto      Int
  id_usuario       Int
  id_rol           Int
  fecha_asignacion DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  activo           Boolean?  @default(true)
  fecha_salida     DateTime? @db.Date
  proyecto         proyecto  @relation(fields: [id_proyecto], references: [id_proyecto], onDelete: Cascade, onUpdate: NoAction)
  rol              rol       @relation(fields: [id_rol], references: [id_rol], onDelete: NoAction, onUpdate: NoAction)
  usuario          usuario   @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@unique([id_proyecto, id_usuario, id_rol])
}

model rol {
  id_rol                Int                     @id @default(autoincrement())
  nombre                String                  @db.VarChar(30)
  descripcion           String?                 @db.Char(200)
  estatus               String?                 @db.Char(1)
  id_proyecto           Int?
  equipo_proyecto       equipo_proyecto[]
  proyecto_participante proyecto_participante[]
  proyecto              proyecto?               @relation(fields: [id_proyecto], references: [id_proyecto], onDelete: NoAction, onUpdate: NoAction, map: "fk_rol_proyecto")
  stakeholder           stakeholder[]
}

model stakeholder {
  id_stakeholder      Int                   @id @default(autoincrement())
  id_rol              Int?
  nombre              String                @db.VarChar(100)
  area                String?               @db.VarChar(50)
  contacto_email      String?               @db.VarChar(60)
  notas               String?
  rol                 rol?                  @relation(fields: [id_rol], references: [id_rol], onDelete: NoAction, onUpdate: NoAction, map: "fk_stakeholder_rol")
  tecnica_recoleccion tecnica_recoleccion[]
}

model subproceso {
  id_subproceso       Int                   @id @default(autoincrement())
  nombre              String                @db.VarChar(100)
  descripcion         String?
  codigo_orden        String                @db.VarChar(10)
  id_proceso          Int
  proceso             proceso               @relation(fields: [id_proceso], references: [id_proceso], onDelete: Cascade, onUpdate: NoAction)
  tecnica_recoleccion tecnica_recoleccion[]
}

model usuario {
  id_usuario            Int                     @id
  nombre                String                  @db.VarChar(50)
  apellido_paterno      String                  @db.VarChar(50)
  apellido_materno      String?                 @db.VarChar(50)
  telefono              Int?
  email                 String                  @db.VarChar(100)
  estatus               String?                 @db.VarChar(1)
  password_hash         String?                 @db.VarChar(64)
  Nombre_usuario        String?                 @db.VarChar(32)
  equipo_proyecto       equipo_proyecto[]
  proyecto              proyecto[]
  proyecto_participante proyecto_participante[]
  entrevistas entrevista[]
}

model equipo_proyecto {
  id_equipo   Int       @id @default(autoincrement())
  id_proyecto Int?
  id_usuario  Int?
  id_rol      Int?
  proyecto    proyecto? @relation(fields: [id_proyecto], references: [id_proyecto], onDelete: NoAction, onUpdate: NoAction)
  rol         rol?      @relation(fields: [id_rol], references: [id_rol], onDelete: NoAction, onUpdate: NoAction)
  usuario     usuario?  @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@unique([id_proyecto, id_usuario, id_rol])
}

model requerimiento {
  id_requerimiento    Int                 @id @default(autoincrement())
  descripcion         String
  codigo_unico        String              @db.VarChar(20)
  id_tecnica          Int
  tecnica_recoleccion tecnica_recoleccion @relation(fields: [id_tecnica], references: [id_tecnica], onDelete: Cascade, onUpdate: NoAction)
}

model tecnica_recoleccion {
  id_tecnica     Int             @id @default(autoincrement())
  tipo           String          @db.VarChar(50)
  detalle        String?
  codigo_orden   String          @db.VarChar(10)
  id_subproceso  Int
  id_stakeholder Int?
  requerimiento  requerimiento[]
  stakeholder    stakeholder?    @relation(fields: [id_stakeholder], references: [id_stakeholder], onDelete: Cascade, onUpdate: NoAction, map: "tecnica_id_stakeholder_fkey")
  subproceso     subproceso      @relation(fields: [id_subproceso], references: [id_subproceso], onDelete: Cascade, onUpdate: NoAction, map: "tecnica_id_subproceso_fkey")
  entrevistas entrevista[]
}

model entrevista {
  id_entrevista    Int       @id @default(autoincrement())
  id_tecnica       Int
  id_usuario       Int
  fecha_entrevista DateTime? @db.Date
  duracion         Int?
  estatus          String     @db.VarChar(20)
  tecnica tecnica_recoleccion @relation(fields: [id_tecnica], references: [id_tecnica], onDelete: Cascade)
  usuario usuario             @relation(fields: [id_usuario], references: [id_usuario])
  preguntas pregunta_entrevista[]
}

model pregunta_entrevista {
  id_pregunta   Int        @id @default(autoincrement())
  id_entrevista Int
  orden_pregunta  Int
  pregunta      String     @db.Text
  respuesta     String?    @db.Text
  entrevista entrevista @relation(fields: [id_entrevista], references: [id_entrevista], onDelete: Cascade)
}